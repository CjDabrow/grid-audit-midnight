# Copy to .env.local and fill in. NEXT_PUBLIC_* are exposed to the browser.

# Network the dApp targets.
NEXT_PUBLIC_MIDNIGHT_NETWORK=TestNet

# Address of the deployed Grid Audit Registry. Set this AFTER running `npm run deploy:registry`.
NEXT_PUBLIC_REGISTRY_ADDRESS=

# Window key the Lace wallet injects its connector under. "mnLace" is typical; confirm for your build.
NEXT_PUBLIC_WALLET_KEY=mnLace

# ---- deploy script only (server-side, NEVER prefixed NEXT_PUBLIC) ----
# Seed phrase / hex seed of a funded testnet wallet used ONCE to deploy the registry.
# Get testnet tDUST from the Midnight faucet first. Do not commit this.
DEPLOY_WALLET_SEED=
